PORT=4000

## Supabase Postgres
# Copy a database connection string from the Supabase dashboard Connect panel.
# Use the direct connection when the backend can reach IPv6, or Session pooler
# when it needs IPv4 support.
DATABASE_URL=postgresql://postgres.project-ref:your-password@aws-0-region.pooler.supabase.com:5432/postgres
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

## Local Postgres fallback
# Leave DATABASE_URL empty when using these local Docker Postgres values.
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

## Secret
ACCESS_TOKEN_SECRET=your_secret
